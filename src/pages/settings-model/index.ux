<template>
  <div class="page">
    <div class="header">
      <input class="back-button" type="button" value="<" onclick="back" />
      <text class="title">模型选择</text>
    </div>

    <div class="menu-list">
      <div class="menu-item" onclick="selectProvider('deepseek')">
        <text class="menu-text">DeepSeek</text>
        <text class="menu-check" if="{{ isDeepseek }}">✓</text>
      </div>
      <div class="menu-item" onclick="selectProvider('glm')">
        <text class="menu-text">GLM</text>
        <text class="menu-check" if="{{ isGlm }}">✓</text>
      </div>
    </div>
  </div>
</template>

<script>
import {writeValue, readValue} from "../../services/storage"
import {STORAGE_KEYS, PROVIDERS} from "../../utils/constants"

export default {
  private: {
    isDeepseek: true,
    isGlm: false
  },

  onShow() {
    setTimeout(
      function() {
        this.loadProvider()
      }.bind(this),
      0
    )
  },

  loadProvider() {
    var self = this;
    readValue(STORAGE_KEYS.MODEL_PROVIDER, function(value) {
      var p = value || PROVIDERS.DEEPSEEK;
      self.isDeepseek = p === PROVIDERS.DEEPSEEK;
      self.isGlm = p === PROVIDERS.GLM;
    });
  },

  selectProvider(provider) {
    var self = this;
    writeValue(STORAGE_KEYS.MODEL_PROVIDER, provider, function() {
      self.isDeepseek = provider === PROVIDERS.DEEPSEEK;
      self.isGlm = provider === PROVIDERS.GLM;
    });
  },

  back() {
    var router = require("@system.router")
    router.back()
  }
}
</script>

<style>
/* 适配 480px 原型表盘与纯黑主题 */
.page {
  width: 480px;
  height: 480px;
  background-color: #000000; /* 纯黑色 OLED 护眼省电 */
}

.header {
  position: absolute;
  top: 20px;
  left: 60px;
  width: 360px;
  height: 38px;
  flex-direction: row;
  align-items: center;
}

.back-button {
  width: 38px;
  height: 34px;
  border-radius: 20px;
  background-color: #1a1a1a; /* 深灰色 */
  color: #ffffff;
  font-size: 18px;
}

.title {
  flex: 1;
  margin-left: 8px;
  font-size: 18px;
  font-weight: bold;
  color: #ffffff;
}

.menu-list {
  position: absolute;
  top: 80px;
  left: 60px;
  width: 360px;
  flex-direction: column;
}

.menu-item {
  width: 100%;
  height: 48px;
  padding: 0 16px;
  border-radius: 20px; /* 大圆角统一 */
  background-color: #1a1a1a; /* 深灰色卡片 */
  flex-direction: row;
  align-items: center;
  margin-bottom: 10px;
}

.menu-text {
  flex: 1;
  font-size: 16px;
  color: #ffffff;
}

.menu-check {
  font-size: 18px;
  color: #1fbf75; /* 绿色选中标记 */
}
</style>
