      <div class="menu-item" onclick="openAbout">
        <text class="menu-text">关于</text>
        <text class="menu-arrow">></text>
      </div>
    </div>
  </div>
</template>

<script>
export default {
  openApiSettings() {
    var router = require("@system.router")
    router.push({
      uri: "/pages/settings-api"
    })
  },

  openModelSettings() {
    var router = require("@system.router")
    router.push({
      uri: "/pages/settings-model"
    })
  },

  openAbout() {
    var router = require("@system.router")
    router.push({
      uri: "/pages/settings-about"
    })
  },

  back() {
    var router = require("@system.router")
    router.back()
  }
}
</script>

