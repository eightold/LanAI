<template>
  <div class="page">
    <div class="header">
      <input class="back-button" type="button" value="<" onclick="back" />
      <text class="title">设置</text>
    </div>

    <div class="menu-list">
      <div class="menu-item" onclick="openApiSettings">
        <text class="menu-text">API</text>
        <text class="menu-arrow">></text>
      </div>
      <div class="menu-item" onclick="openModelSettings">
