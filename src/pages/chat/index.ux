<template>
  <div class="page">
    <div class="header">
      <input class="back-button" type="button" value="<" onclick="back" />
      <text class="title">{{ title }}</text>
    </div>

    <div class="messages">
      <div class="message-row" for="item in displayMessages">
        <text class="bubble">{{ item.content }}</text>
      </div>
    </div>

    <div class="input-area">
      <input
        class="message-input"
        type="text"
        placeholder="Ask AI"
        value="{{ draft }}"
        onchange="updateDraft"
      />
      <input class="send-button" type="button" value="Send" onclick="send" />
    </div>
  </div>
</template>

<script>
var CHAT_LIST_KEY = "chat_list"
var CURRENT_CHAT_ID_KEY = "current_chat_id"

function getChatKey(id) {
  return "chat_" + id
}

export default {
  private: {
    chatId: "",
    title: "Chat",
    draft: "",
    messages: [],
    displayMessages: [
      {
        id: "welcome",
        content: "AI: Local chat ready"
      }
    ]
  },

  onShow() {
    setTimeout(
      function() {
        this.loadChat()
      }.bind(this),
      0
    )
  },

  getStorage() {
    try {
      return require("@system.storage")
    } catch (error) {
      console.error("storage unavailable", error)
      return null
    }
  },

  readValue(key, done) {
    var storage = this.getStorage()

    if (!storage) {
      done("")
      return
    }

    storage.get({
      key: key,
      success: function(value) {
        done(value || "")
      },
      fail: function() {
        done("")
      }
    })
  },

  readJson(key, fallback, done) {
    this.readValue(key, function(value) {
      if (!value) {
        done(fallback)
        return
      }

      try {
        done(JSON.parse(value))
      } catch (error) {
        done(fallback)
      }
    })
  },

  writeJson(key, value, done) {
    var storage = this.getStorage()

    if (!storage) {
      if (done) {
        done()
      }
      return
    }

    storage.set({
      key: key,
      value: JSON.stringify(value),
      success: function() {
        if (done) {
          done()
        }
      },
      fail: function() {
        if (done) {
          done()
        }
      }
    })
  },

  normalizeMessages(messages) {
    var source = messages || []
    var display = []
    var index = 0

    for (index = 0; index < source.length; index++) {
      display.push({
        id: source[index].id,
        content: (source[index].role === "user" ? "You: " : "AI: ") + source[index].content
      })
    }

    if (display.length === 0) {
      display.push({
        id: "welcome",
        content: "AI: Local chat ready"
      })
    }

    this.displayMessages = display
  },

  loadChat() {
    this.readValue(
      CURRENT_CHAT_ID_KEY,
      function(chatId) {
        var id = chatId || "local_chat"
        this.chatId = id
        this.readJson(
          getChatKey(id),
          {
            id: id,
            title: "Local Chat",
            messages: []
          },
          function(chat) {
            this.title = chat.title || "Chat"
            this.messages = chat.messages || []
            this.normalizeMessages(this.messages)
          }.bind(this)
        )
      }.bind(this)
    )
  },

  updateDraft(event) {
    var value = (event && event.value) || ""
    this.draft = value.slice(0, 200)
  },

  saveChat(done) {
    var title = this.title

    if (title === "Local Chat" && this.messages.length > 0) {
      title = this.messages[0].content.slice(0, 16) || title
    }

    this.title = title
    this.writeJson(
      getChatKey(this.chatId),
      {
        id: this.chatId,
        title: title,
        messages: this.messages,
        updateTime: Date.now()
      },
      function() {
        this.syncChatList(title, done)
      }.bind(this)
    )
  },

  syncChatList(title, done) {
    this.readJson(
      CHAT_LIST_KEY,
      [],
      function(list) {
        var nextList = []
        var found = false
        var i = 0
        var preview = this.messages.length > 0 ? this.messages[this.messages.length - 1].content : "Local conversation"

        for (i = 0; i < list.length; i++) {
          if (list[i].id === this.chatId) {
            nextList.push({
              id: this.chatId,
              title: title,
              preview: preview,
              updateTime: Date.now()
            })
            found = true
          } else {
            nextList.push(list[i])
          }
        }

        if (!found) {
          nextList.unshift({
            id: this.chatId,
            title: title,
            preview: preview,
            updateTime: Date.now()
          })
        }

        this.writeJson(CHAT_LIST_KEY, nextList, done)
      }.bind(this)
    )
  },

  send() {
    var content = (this.draft || "").trim()

    if (!content) {
      return
    }

    this.messages = this.messages.concat([
      {
        id: "user_" + Date.now(),
        role: "user",
        content: content
      },
      {
        id: "ai_" + Date.now(),
        role: "assistant",
        content: "DeepSeek is not connected yet"
      }
    ])
    this.draft = ""
    this.normalizeMessages(this.messages)
    this.saveChat(function() {})
  },

  back() {
    var router = require("@system.router")
    router.back()
  }
}
</script>

<style>
.page {
  width: 100%;
  height: 100%;
  padding: 20px 18px 18px;
  flex-direction: column;
  background-color: #101418;
}

.header {
  height: 38px;
  flex-direction: row;
  align-items: center;
}

.back-button {
  width: 38px;
  height: 34px;
  border-radius: 16px;
  background-color: #25313d;
  color: #ffffff;
  font-size: 18px;
}

.title {
  flex: 1;
  margin-left: 8px;
  font-size: 18px;
  font-weight: bold;
  color: #ffffff;
  lines: 1;
}

.messages {
  flex: 1;
  margin-top: 8px;
  flex-direction: column;
}

.message-row {
  width: 100%;
  margin-bottom: 8px;
  align-items: flex-start;
}

.bubble {
  max-width: 82%;
  padding: 9px 12px;
  border-radius: 15px;
  font-size: 14px;
  line-height: 20px;
  background-color: #25313d;
  color: #f8fafc;
}

.input-area {
  height: 48px;
  margin-top: 6px;
  flex-direction: row;
  align-items: center;
}

.message-input {
  flex: 1;
  height: 44px;
  padding: 0 12px;
  border-radius: 16px;
  background-color: #1f2933;
  color: #ffffff;
  font-size: 15px;
}

.send-button {
  width: 72px;
  height: 44px;
  margin-left: 8px;
  border-radius: 16px;
  background-color: #f4c542;
  color: #1b1b12;
  font-size: 15px;
  font-weight: bold;
}
</style>
