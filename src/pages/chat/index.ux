<import name="input-method" src="../../InputMethod/InputMethod.ux"></import>
<template>
  <div class="page">
    <div class="header">
      <input class="back-button" type="button" value="<" onclick="back" />
      <text class="title">{{ title }}</text>
    </div>
    
    <scroll id="msgScroll" scroll-y="{{true}}" bounces="{{true}}" class="msg-scroll" style="height: {{ msgHeight }}px;">
      <div class="message-row {{ item.isUser ? 'row-user' : 'row-ai' }}" for="item in displayMessages">
        <text class="bubble {{ item.isUser ? 'bubble-user' : 'bubble-ai' }}">{{ item.content }}</text>
      </div>
    </scroll>

    <div class="input-area" style="bottom: {{ inputBottom }}px;">
      <div class="message-input" onclick="toggleKeyboard">
        <text class="draft-text" if="{{ draft }}">{{ draft }}</text>
        <text class="placeholder-text" if="{{ !draft }}">Ask AI...</text>
      </div>
      <input class="send-button" if="{{ !keyboardHide }}" type="button" value="Send" onclick="send" />
    </div>

    <input-method
      hide="{{ keyboardHide }}"
      keyboardtype="QWERTY"
      maxlength="5"
      vibratemode="short"
      screentype="circle"
      @complete="onInputComplete"
      @delete="onInputDelete"
    ></input-method>
  </div>
</template>

<script>
import { sendChatMessage } from "../../services/deepseek"
import {
  DEEPSEEK_API_KEY,
  DEEPSEEK_ENDPOINT,
  DEEPSEEK_MAX_TOKENS,
  DEEPSEEK_MODEL,
  GLM_API_KEY,
  GLM_ENDPOINT,
  GLM_MAX_TOKENS,
  GLM_MODEL,
  STORAGE_KEYS,
  PROVIDERS
} from "../../utils/constants"
import { readValue } from "../../services/storage"
import { saveFullChat, getChat, getCurrentChatId } from "../../services/chat"
import { createId } from "../../utils/uuid"

export default {
  private: {
    chatId: "",
    title: "Chat",
    draft: "",
    messages: [],
    createTime: null,
    requestState: "idle",
    keyboardHide: true,
    msgBottom: 84, 
    inputBottom: 24,
    msgHeight: 326, 
    displayMessages: [
      {
        id: "welcome",
        isUser: false,
        content: "Local chat ready"
      }
    ]
  },

  onShow() {
    setTimeout(
      function() {
        this.loadChat()
      }.bind(this),
      0
    )
  },

  normalizeMessages(messages) {
    var source = messages || []
    var display = []
    var index = 0

    for (index = 0; index < source.length; index++) {
      display.push({
        id: source[index].id,
        isUser: source[index].role === "user",
        content: source[index].content
      })
    }

    if (display.length === 0) {
      display.push({
        id: "welcome",
        isUser: false,
        content: "Local chat ready"
      })
    }

    this.displayMessages = display
  },

  scrollToBottom() {
    var self = this;
    setTimeout(function() {
      self.$element("msgScroll").scrollTo({
        top: 99999,
        behavior: "smooth"
      });
    }, 100);
  },

  loadChat() {
    getCurrentChatId(function(chatId) {
      var id = chatId || "local_chat"
      this.chatId = id
      getChat(id, function(chat) {
        var session = chat || { id: id, title: "Local Chat", messages: [] }
        this.title = session.title || "Chat"
        this.messages = session.messages || []
        this.createTime = session.createTime || Date.now()
        this.normalizeMessages(this.messages)
        this.scrollToBottom()
      }.bind(this))
    }.bind(this))
  },

  toggleKeyboard() {
    this.keyboardHide = !this.keyboardHide;
    this.updateLayout();
  },

  updateLayout() {
    if (this.keyboardHide) {
      this.msgBottom = 84;  
      this.inputBottom = 24; 
    } else {
      this.msgBottom = 393;
      this.inputBottom = 339;
    }
    this.msgHeight = 480 - 70 - this.msgBottom;
  },

  onInputComplete(evt) {
    var ch = (evt && evt.detail && evt.detail.content) || "";
    var current = this.draft || "";
    if (current.length < 200) {
      this.draft = current + ch;
    }
  },

  onInputDelete() {
    var current = this.draft || "";
    this.draft = current.slice(0, -1);
  },

  send() {
    var content = (this.draft || "").trim();
    if (!content || this.requestState === "loading") {
      return;
    }

    this.draft = "";
    this.keyboardHide = true;
    this.updateLayout();

    var loadingId = "loading_" + Date.now();
    var userMsg = {
      id: createId("msg"),
      role: "user",
      content: content,
      timestamp: Date.now()
    };

    this.messages = this.messages.concat([
      userMsg,
      { id: loadingId, role: "assistant", content: "Thinking..." }
    ]);
    this.requestState = "loading";

    if (this.title === "Local Chat" && this.messages.length > 0) {
      this.title = content.slice(0, 16) || this.title;
    }

    this.normalizeMessages(this.messages);
    this.scrollToBottom();

    var messagesForSave = this.messages.filter(function(m) {
      return m.id.indexOf("loading_") !== 0;
    });
    saveFullChat(this.chatId, this.title, this.createTime, messagesForSave, function() {});

    var apiMessages = messagesForSave.map(function(m) {
      return { role: m.role, content: m.content };
    });

    var self = this;
    this.getApiConfig(function(config) {
      sendChatMessage(
        apiMessages,
        function(answer) {
          var aiMsg = {
            id: createId("msg"),
            role: "assistant",
            content: answer,
            timestamp: Date.now()
          };
          self.replaceMessage(loadingId, aiMsg);
          self.requestState = "idle";
          self.normalizeMessages(self.messages);
          self.scrollToBottom();

          var finalMessages = self.messages.filter(function(m) {
            return m.id.indexOf("loading_") !== 0;
          });
          saveFullChat(self.chatId, self.title, self.createTime, finalMessages, function() {});
        },
        function(error) {
          var msg = "Network error";
          if (error && error.message) {
            msg = error.message;
          }
          var errMsg = {
            id: createId("msg"),
            role: "assistant",
            content: msg + ", please retry",
            timestamp: Date.now()
          };
          self.replaceMessage(loadingId, errMsg);
          self.requestState = "idle";
          self.normalizeMessages(self.messages);

          var finalMessages = self.messages.filter(function(m) {
            return m.id.indexOf("loading_") !== 0;
          });
          saveFullChat(self.chatId, self.title, self.createTime, finalMessages, function() {});
        },
        config.key,
        config.endpoint,
        config.model,
        config.maxTokens
      );
    });
  },

  getApiConfig(done) {
    readValue(STORAGE_KEYS.MODEL_PROVIDER, function(provider) {
      var p = provider || PROVIDERS.DEEPSEEK;
      var keyStorage = p === PROVIDERS.GLM ? STORAGE_KEYS.GLM_API_KEY : STORAGE_KEYS.API_KEY;
      var defaultKey = p === PROVIDERS.GLM ? GLM_API_KEY : DEEPSEEK_API_KEY;
      var endpoint = p === PROVIDERS.GLM ? GLM_ENDPOINT : DEEPSEEK_ENDPOINT;
      var model = p === PROVIDERS.GLM ? GLM_MODEL : DEEPSEEK_MODEL;
      var maxTokens = p === PROVIDERS.GLM ? GLM_MAX_TOKENS : DEEPSEEK_MAX_TOKENS;

      readValue(keyStorage, function(value) {
        done({
          key: value || defaultKey,
          endpoint: endpoint,
          model: model,
          maxTokens: maxTokens
        });
      });
    });
  },

  replaceMessage(oldId, newMsg) {
    this.messages = this.messages.map(function(m) {
      return m.id === oldId ? newMsg : m;
    });
  },

  back() {
    var router = require("@system.router")
    router.back()
  }
}
</script>

<style>
/* 统一深色主题与 480px 表盘防裁切适配 */
.page {
  width: 480px;
  height: 480px;
  background-color: #000000;
}

.header {
  position: absolute;
  top: 25px; 
  left: 80px; 
  width: 320px;
  height: 40px;
  flex-direction: row;
  align-items: center;
}

.back-button {
  width: 38px;
  height: 34px;
  border-radius: 19px; 
  background-color: #1a1a1a; 
  color: #ffffff;
  font-size: 18px;
}

.title {
  flex: 1;
  margin-left: 12px;
  font-size: 18px;
  font-weight: bold;
  color: #ffffff;
  lines: 1;
}

.msg-scroll {
  position: absolute;
  top: 70px;
  left: 60px; 
  width: 360px;
  flex-direction: column;
}

.message-row {
  width: 100%;
  margin-bottom: 12px; 
  flex-direction: row;
}

.row-user {
  justify-content: flex-end; 
}

.row-ai {
  justify-content: flex-start; 
}

.bubble {
  max-width: 82%;
  padding: 12px 16px;
  border-radius: 20px;
  font-size: 15px; 
  line-height: 22px;
}

.bubble-ai {
  background-color: #1a1a1a;
  color: #ffffff;
  border-top-left-radius: 4px; 
}

.bubble-user {
  background-color: #1fbf75;
  color: #000000;
  border-top-right-radius: 4px; 
}

.input-area {
  position: absolute;
  left: 80px; 
  width: 320px;
  height: 48px;
  flex-direction: row;
  align-items: center;
}

.message-input {
  flex: 1;
  height: 44px;
  padding: 0 16px;
  border-radius: 22px; 
  background-color: #1a1a1a; 
  /* 修复文字偏上并靠左对齐 */
  flex-direction: row;
  align-items: center; 
  justify-content: flex-start; 
}

.draft-text {
  font-size: 15px;
  color: #ffffff;
  line-height: 20px; /* 增加具体行高，辅助引擎对齐 */
  lines: 1; 
}

.placeholder-text {
  font-size: 15px;
  color: #888888; 
  line-height: 20px;
}

.send-button {
  width: 72px;
  height: 44px;
  margin-left: 10px;
  border-radius: 22px; 
  background-color: #1fbf75; 
  color: #000000; 
  font-size: 15px;
  font-weight: bold;
}
</style>