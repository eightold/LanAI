<import name="input-method" src="../../InputMethod/InputMethod.ux"></import>
<template>
  <div class="page">
    <div class="header">
      <input class="back-button" type="button" value="<" onclick="back" />
      <text class="title">{{ title }}</text>
    </div>

    <div class="messages" style="bottom: {{ msgBottom }}px;">
      <scroll id="msgScroll" style="flex: 1; flex-direction: column;">
        <div class="message-row" for="item in displayMessages">
          <text class="bubble">{{ item.content }}</text>
        </div>
      </scroll>
    </div>

    <div class="input-area" style="bottom: {{ inputBottom }}px;">
      <div class="message-input" onclick="toggleKeyboard">
        <text class="draft-text" if="{{ draft }}">{{ draft }}</text>
        <text class="placeholder-text" if="{{ !draft }}">Ask AI</text>
      </div>
      <input class="send-button" type="button" value="Send" onclick="send" />
    </div>

    <input-method
      hide="{{ keyboardHide }}"
      keyboardtype="QWERTY"
      maxlength="5"
      vibratemode="short"
      screentype="circle"
      @complete="onInputComplete"
      @delete="onInputDelete"
    ></input-method>
  </div>
</template>

<script>
import { sendChatMessage } from "../../services/deepseek"
import {
  DEEPSEEK_API_KEY,
  DEEPSEEK_ENDPOINT,
  DEEPSEEK_MAX_TOKENS,
  DEEPSEEK_MODEL,
  GLM_API_KEY,
  GLM_ENDPOINT,
  GLM_MAX_TOKENS,
  GLM_MODEL,
  STORAGE_KEYS,
  PROVIDERS
} from "../../utils/constants"

var CHAT_LIST_KEY = "chat_list"
var CURRENT_CHAT_ID_KEY = "current_chat_id"

function getChatKey(id) {
  return "chat_" + id
}

export default {
  private: {
    chatId: "",
    title: "Chat",
    draft: "",
    messages: [],
    requestState: "idle",
    keyboardHide: true,
    msgBottom: 72,
    inputBottom: 18,
    displayMessages: [
      {
        id: "welcome",
        content: "AI: Local chat ready"
      }
    ]
  },

  onShow() {
    setTimeout(
      function() {
        this.loadChat()
      }.bind(this),
      0
    )
  },

  getStorage() {
    try {
      return require("@system.storage")
    } catch (error) {
      console.error("storage unavailable", error)
      return null
    }
  },

  readValue(key, done) {
    var storage = this.getStorage()

    if (!storage) {
      done("")
      return
    }

    storage.get({
      key: key,
      success: function(value) {
        done(value || "")
      },
      fail: function() {
        done("")
      }
    })
  },

  readJson(key, fallback, done) {
    this.readValue(key, function(value) {
      if (!value) {
        done(fallback)
        return
      }

      try {
        done(JSON.parse(value))
      } catch (error) {
        done(fallback)
      }
    })
  },

  writeJson(key, value, done) {
    var storage = this.getStorage()

    if (!storage) {
      if (done) {
        done()
      }
      return
    }

    storage.set({
      key: key,
      value: JSON.stringify(value),
      success: function() {
        if (done) {
          done()
        }
      },
      fail: function() {
        if (done) {
          done()
        }
      }
    })
  },

  normalizeMessages(messages) {
    var source = messages || []
    var display = []
    var index = 0

    for (index = 0; index < source.length; index++) {
      display.push({
        id: source[index].id,
        content: (source[index].role === "user" ? "You: " : "AI: ") + source[index].content
      })
    }

    if (display.length === 0) {
      display.push({
        id: "welcome",
        content: "AI: Local chat ready"
      })
    }

    this.displayMessages = display
  },

  scrollToBottom() {
    var self = this;
    setTimeout(function() {
      self.$element("msgScroll").scrollTo({
        top: 99999,
        behavior: "smooth"
      });
    }, 100);
  },

  loadChat() {
    this.readValue(
      CURRENT_CHAT_ID_KEY,
      function(chatId) {
        var id = chatId || "local_chat"
        this.chatId = id
        this.readJson(
          getChatKey(id),
          {
            id: id,
            title: "Local Chat",
            messages: []
          },
          function(chat) {
            this.title = chat.title || "Chat"
            this.messages = chat.messages || []
            this.normalizeMessages(this.messages)
            this.scrollToBottom()
          }.bind(this)
        )
      }.bind(this)
    )
  },

  toggleKeyboard() {
    this.keyboardHide = !this.keyboardHide;
    this.updateLayout();
  },

  updateLayout() {
    if (this.keyboardHide) {
      this.msgBottom = 72;
      this.inputBottom = 18;
    } else {
      this.msgBottom = 393;
      this.inputBottom = 339;
    }
  },

  onInputComplete(evt) {
    var ch = (evt && evt.detail && evt.detail.content) || "";
    var current = this.draft || "";
    if (current.length < 200) {
      this.draft = current + ch;
    }
  },

  onInputDelete() {
    var current = this.draft || "";
    this.draft = current.slice(0, -1);
  },

  saveChat(done) {
    var title = this.title

    if (title === "Local Chat" && this.messages.length > 0) {
      title = this.messages[0].content.slice(0, 16) || title
    }

    this.title = title
    this.writeJson(
      getChatKey(this.chatId),
      {
        id: this.chatId,
        title: title,
        messages: this.messages,
        updateTime: Date.now()
      },
      function() {
        this.syncChatList(title, done)
      }.bind(this)
    )
  },

  syncChatList(title, done) {
    this.readJson(
      CHAT_LIST_KEY,
      [],
      function(list) {
        var nextList = []
        var found = false
        var i = 0
        var preview = this.messages.length > 0 ? this.messages[this.messages.length - 1].content : "Local conversation"

        for (i = 0; i < list.length; i++) {
          if (list[i].id === this.chatId) {
            nextList.push({
              id: this.chatId,
              title: title,
              preview: preview,
              updateTime: Date.now()
            })
            found = true
          } else {
            nextList.push(list[i])
          }
        }

        if (!found) {
          nextList.unshift({
            id: this.chatId,
            title: title,
            preview: preview,
            updateTime: Date.now()
          })
        }

        this.writeJson(CHAT_LIST_KEY, nextList, done)
      }.bind(this)
    )
  },

  send() {
    var content = (this.draft || "").trim();
    if (!content || this.requestState === "loading") {
      return;
    }

    this.draft = "";
    this.keyboardHide = true;
    this.updateLayout();

    var loadingId = "loading_" + Date.now();
    this.messages = this.messages.concat([
      { id: "user_" + Date.now(), role: "user", content: content },
      { id: loadingId, role: "assistant", content: "Thinking..." }
    ]);
    this.requestState = "loading";

    this.normalizeMessages(this.messages);
    this.scrollToBottom();
    this.saveChat(function() {});

    var apiMessages = [];
    for (var i = 0; i < this.messages.length; i++) {
      if (this.messages[i].id !== loadingId) {
        apiMessages.push({
          role: this.messages[i].role,
          content: this.messages[i].content
        });
      }
    }

    var self = this;
    this.getApiConfig(function(config) {
      sendChatMessage(
        apiMessages,
        function(answer) {
          self.replaceMessage(loadingId, {
            id: "ai_" + Date.now(),
            role: "assistant",
            content: answer
          });
          self.requestState = "idle";
          self.normalizeMessages(self.messages);
          self.scrollToBottom();
          self.saveChat(function() {});
        },
        function(error) {
          var msg = "Network error";
          if (error && error.message) {
            msg = error.message;
          }
          self.replaceMessage(loadingId, {
            id: "error_" + Date.now(),
            role: "assistant",
            content: msg + ", please retry"
          });
          self.requestState = "idle";
          self.normalizeMessages(self.messages);
          self.saveChat(function() {});
        },
        config.key,
        config.endpoint,
        config.model,
        config.maxTokens
      );
    });
  },

  getApiConfig(done) {
    var storage = this.getStorage();

    if (!storage) {
      done({
        key: DEEPSEEK_API_KEY,
        endpoint: DEEPSEEK_ENDPOINT,
        model: DEEPSEEK_MODEL,
        maxTokens: DEEPSEEK_MAX_TOKENS
      });
      return;
    }

    storage.get({
      key: STORAGE_KEYS.MODEL_PROVIDER,
      success: function(provider) {
        var p = provider || PROVIDERS.DEEPSEEK;
        var keyStorage = p === PROVIDERS.GLM ? STORAGE_KEYS.GLM_API_KEY : STORAGE_KEYS.API_KEY;
        var defaultKey = p === PROVIDERS.GLM ? GLM_API_KEY : DEEPSEEK_API_KEY;
        var endpoint = p === PROVIDERS.GLM ? GLM_ENDPOINT : DEEPSEEK_ENDPOINT;
        var model = p === PROVIDERS.GLM ? GLM_MODEL : DEEPSEEK_MODEL;
        var maxTokens = p === PROVIDERS.GLM ? GLM_MAX_TOKENS : DEEPSEEK_MAX_TOKENS;

        storage.get({
          key: keyStorage,
          success: function(value) {
            done({
              key: value || defaultKey,
              endpoint: endpoint,
              model: model,
              maxTokens: maxTokens
            });
          },
          fail: function() {
            done({
              key: defaultKey,
              endpoint: endpoint,
              model: model,
              maxTokens: maxTokens
            });
          }
        });
      }.bind(this),
      fail: function() {
        storage.get({
          key: STORAGE_KEYS.API_KEY,
          success: function(value) {
            done({
              key: value || DEEPSEEK_API_KEY,
              endpoint: DEEPSEEK_ENDPOINT,
              model: DEEPSEEK_MODEL,
              maxTokens: DEEPSEEK_MAX_TOKENS
            });
          },
          fail: function() {
            done({
              key: DEEPSEEK_API_KEY,
              endpoint: DEEPSEEK_ENDPOINT,
              model: DEEPSEEK_MODEL,
              maxTokens: DEEPSEEK_MAX_TOKENS
            });
          }
        });
      }.bind(this)
    });
  },

  replaceMessage(oldId, newMsg) {
    var arr = [];
    for (var i = 0; i < this.messages.length; i++) {
      if (this.messages[i].id === oldId) {
        arr.push(newMsg);
      } else {
        arr.push(this.messages[i]);
      }
    }
    this.messages = arr;
  },

  back() {
    var router = require("@system.router")
    router.back()
  }
}
</script>

<style>
.page {
  width: 100%;
  height: 100%;
  background-color: #101418;
}

.header {
  position: absolute;
  top: 20px;
  left: 18px;
  right: 18px;
  height: 38px;
  flex-direction: row;
  align-items: center;
}

.back-button {
  width: 38px;
  height: 34px;
  border-radius: 16px;
  background-color: #25313d;
  color: #ffffff;
  font-size: 18px;
}

.title {
  flex: 1;
  margin-left: 8px;
  font-size: 18px;
  font-weight: bold;
  color: #ffffff;
  lines: 1;
}

.messages {
  position: absolute;
  top: 66px;
  left: 18px;
  right: 18px;
  flex-direction: column;
}

.message-row {
  width: 100%;
  margin-bottom: 8px;
  align-items: flex-start;
}

.bubble {
  max-width: 82%;
  padding: 9px 12px;
  border-radius: 15px;
  font-size: 14px;
  line-height: 20px;
  background-color: #25313d;
  color: #f8fafc;
}

.input-area {
  position: absolute;
  left: 18px;
  right: 18px;
  height: 48px;
  flex-direction: row;
  align-items: center;
}

.message-input {
  flex: 1;
  height: 44px;
  padding: 0 12px;
  border-radius: 16px;
  background-color: #1f2933;
  justify-content: center;
}

.draft-text {
  font-size: 15px;
  color: #ffffff;
}

.placeholder-text {
  font-size: 15px;
  color: #6b7a8a;
}

.send-button {
  width: 72px;
  height: 44px;
  margin-left: 8px;
  border-radius: 16px;
  background-color: #f4c542;
  color: #1b1b12;
  font-size: 15px;
  font-weight: bold;
}
</style>
