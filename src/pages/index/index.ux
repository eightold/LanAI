<template>
  <div class="page">
    <text class="title" onclick="openSettings">LanAI</text>

    <div class="empty" if="{{ isEmpty }}">
      <text class="empty-title">No Chats</text>
      <text class="empty-subtitle">Tap New Chat</text>
    </div>

    <scroll class="chat-list" scroll-y="{{true}}" bounces="{{true}}" if="{{ hasChats }}">
      <div class="chat-card" for="item in chats" onclick="openChat(item.id)" onlongpress="removeChat(item.id)">
        <text class="chat-title">{{ item.title }}</text>
        <text class="chat-preview">{{ item.preview }}</text>
      </div>
    </scroll>

    <input class="new-button" type="button" value="+ New Chat" onclick="startChat" />
  </div>
</template>

<script>
var CHAT_LIST_KEY = "chat_list"
var CURRENT_CHAT_ID_KEY = "current_chat_id"

function createId(prefix) {
  var random = Math.random().toString(36).slice(2, 8)
  return prefix + "_" + Date.now() + "_" + random
}

export default {
  private: {
    chats: [],
    hasChats: false,
    isEmpty: true
  },

  onShow() {
    setTimeout(
      function() {
        this.refresh()
      }.bind(this),
      0
    )
  },

  getStorage() {
    if (this._storage !== undefined) {
      return this._storage
    }
    try {
      this._storage = require("@system.storage")
      return this._storage
    } catch (error) {
      console.error("storage unavailable", error)
      this._storage = null
      return null
    }
  },

  readJson(key, fallback, done) {
    var storage = this.getStorage()

    if (!storage) {
      done(fallback)
      return
    }

    var self = this
    storage.get({
      key: key,
      success: function(value) {
        if (!value) {
          done(fallback)
          return
        }

        try {
          done(JSON.parse(value))
        } catch (error) {
          console.error("storage parse error for key " + key, error)
          self.writeJson(key, fallback, function() {
            done(fallback)
          })
        }
      },
      fail: function() {
        done(fallback)
      }
    })
  },

  writeJson(key, value, done) {
    var storage = this.getStorage()

    if (!storage) {
      if (done) {
        done()
      }
      return
    }

    storage.set({
      key: key,
      value: JSON.stringify(value),
      success: function() {
        if (done) {
          done()
        }
      },
      fail: function() {
        if (done) {
          done()
        }
      }
    })
  },

  removeValue(key, done) {
    var storage = this.getStorage()
    var removeApi = storage && (storage.delete || storage.remove)

    if (!removeApi) {
      if (done) {
        done()
      }
      return
    }

    removeApi({
      key: key,
      success: function() {
        if (done) {
          done()
        }
      },
      fail: function() {
        if (done) {
          done()
        }
      }
    })
  },

  showToast(message) {
    try {
      var prompt = require("@system.prompt")
      prompt.showToast({
        message: message
      })
    } catch (error) {
      console.log(message)
    }
  },

  refresh() {
    this.readJson(
      CHAT_LIST_KEY,
      [],
      function(chats) {
        var list = chats || []
        this.chats = list
        this.hasChats = list.length > 0
        this.isEmpty = list.length === 0
      }.bind(this)
    )
  },

  startChat() {
    var chat = {
      id: createId("chat"),
      title: "New Chat",
      preview: "Local conversation",
      updateTime: Date.now()
    }
    var list = [chat].concat(this.chats || [])

    this.writeJson(
      CHAT_LIST_KEY,
      list,
      function() {
        this.openChat(chat.id)
      }.bind(this)
    )
  },

  openChat(id) {
    var storage = this.getStorage()
    var router = require("@system.router")

    if (!storage) {
      router.push({
        uri: "/pages/chat"
      })
      return
    }

    storage.set({
      key: CURRENT_CHAT_ID_KEY,
      value: id,
      success: function() {
        router.push({
          uri: "/pages/chat"
        })
      },
      fail: function() {
        router.push({
          uri: "/pages/chat"
        })
      }
    })
  },

  removeChat(id) {
    var nextList = this.chats.filter(function(item) {
      return item.id !== id
    })

    this.writeJson(
      CHAT_LIST_KEY,
      nextList,
      function() {
        this.removeValue(
          "chat_" + id,
          function() {
            this.chats = nextList
            this.hasChats = nextList.length > 0
            this.isEmpty = nextList.length === 0
            this.showToast("Chat deleted")
          }.bind(this)
        )
      }.bind(this)
    )
  },

  openSettings() {
    var router = require("@system.router")
    router.push({
      uri: "/pages/settings"
    })
  }
}
</script>

<style>
/* 适配 480px 原型表盘与纯黑主题 */
.page {
  width: 480px;
  height: 480px;
  background-color: #000000; /* 纯黑色 OLED 护眼省电 */
}

.title {
  position: absolute;
  top: 35px; /* 下移以避开顶部圆弧裁切 */
  width: 480px; /* 撑满后利用 text-align 居中 */
  height: 40px;
  font-size: 24px;
  font-weight: bold;
  text-align: center;
  color: #ffffff;
}

.empty {
  position: absolute;
  top: 150px;
  left: 90px;
  width: 300px;
  height: 180px;
  justify-content: center;
  align-items: center;
  flex-direction: column;
}

.empty-title {
  font-size: 22px;
  color: #ffffff;
}

.empty-subtitle {
  margin-top: 10px;
  font-size: 16px;
  color: #888888;
}

.chat-list {
  position: absolute;
  top: 90px;
  left: 60px; /* 两侧留白，防止滚动列表碰到圆形边缘 */
  width: 360px;
  height: 280px;
  flex-direction: column;
}

.chat-card {
  width: 100%;
  min-height: 64px;
  margin-bottom: 12px;
  padding: 12px 16px;
  border-radius: 20px; /* 增大圆角，更符合手表 UI */
  background-color: #1a1a1a; /* 深灰色卡片，与纯黑背景区分 */
  flex-direction: column;
  justify-content: center;
}

.chat-title {
  font-size: 18px;
  color: #ffffff;
  lines: 1;
}

.chat-preview {
  margin-top: 4px;
  font-size: 14px;
  color: #888888; /* 弱化预览文字颜色 */
  lines: 1;
}

.new-button {
  position: absolute;
  left: 140px;
  top: 390px; /* 固定在表盘底部居中偏上位置 */
  width: 200px;
  height: 50px;
  border-radius: 25px; /* 圆角药丸形按钮 */
  background-color: #1fbf75; /* 保持强调色 */
  color: #000000; /* 黑色字体搭配绿色底色，对比度更清晰 */
  font-size: 18px;
  font-weight: bold;
}
</style>